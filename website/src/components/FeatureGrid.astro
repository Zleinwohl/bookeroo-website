---
interface Feature {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
  columns?: 2 | 3 | 4;
  light?: boolean;
}

const { features, columns = 3, light = false } = Astro.props;
const gridCols = {
  2: 'grid-cols-1 md:grid-cols-2',
  3: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-3',
  4: 'grid-cols-1 md:grid-cols-2 lg:grid-cols-4',
}[columns];
---
<div class:list={["grid gap-6", gridCols]}>
  {features.map(feature => (
    <div class:list={[
      "group rounded-xl p-6 border transition-all hover:-translate-y-1",
      light
        ? "bg-white border-zinc-200 hover:border-zinc-300 hover:shadow-lg"
        : "bg-zinc-900 border-zinc-800 hover:border-zinc-600 hover:shadow-xl hover:shadow-zinc-950/50"
    ]}>
      <div class="text-2xl mb-4">{feature.icon}</div>
      <h3 class:list={["font-semibold mb-2", light ? "text-zinc-900" : "text-zinc-100"]}>
        {feature.title}
      </h3>
      <p class:list={["text-sm leading-relaxed", light ? "text-zinc-600" : "text-zinc-500"]}>
        {feature.description}
      </p>
    </div>
  ))}
</div>
