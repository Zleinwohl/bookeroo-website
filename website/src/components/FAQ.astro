---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items?: FAQItem[];
}

const { items = [
  {
    question: "How long does it take to get set up?",
    answer: "Most operators are fully set up and taking bookings within a day. Our onboarding team walks you through the setup step by step."
  },
  {
    question: "Do my customers need to download anything?",
    answer: "No. The customer booking experience is entirely web-based. Your customers book directly from your website or a link you share."
  },
  {
    question: "Can I manage multiple tours or experiences?",
    answer: "Yes. You can create as many tours, activities, or experiences as you need, each with their own schedules, capacity, and pricing."
  },
  {
    question: "How does staff scheduling work?",
    answer: "You assign staff to tours and time slots directly in the dashboard. Staff can view their schedules and you get a clear picture of who is working when."
  },
  {
    question: "Is Bookeroo cheaper than FareHarbor or Peek Pro?",
    answer: "Bookeroo is designed to be more affordable for small and mid-size operators, with straightforward pricing and no hidden fees."
  },
] } = Astro.props;
---
<div class="space-y-3">
  {items.map((item, i) => (
    <details class="group bg-zinc-900 border border-zinc-800 hover:border-zinc-700 rounded-xl overflow-hidden transition-colors">
      <summary class="flex items-center justify-between px-6 py-5 cursor-pointer list-none">
        <span class="font-medium text-zinc-200 text-sm md:text-base pr-4">{item.question}</span>
        <svg class="w-5 h-5 text-zinc-500 flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
        </svg>
      </summary>
      <div class="px-6 pb-5">
        <p class="text-sm text-zinc-500 leading-relaxed">{item.answer}</p>
      </div>
    </details>
  ))}
</div>
