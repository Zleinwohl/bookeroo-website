---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  size?: 'full' | 'contained';
}
const { src, alt, caption, size = 'full' } = Astro.props;
---

<div class="screenshot-panel group relative">
  <!-- Browser chrome -->
  <div class="bg-zinc-800 border border-zinc-700 rounded-t-xl px-4 py-3 flex items-center gap-3">
    <div class="flex items-center gap-1.5">
      <div class="w-3 h-3 rounded-full bg-zinc-600"></div>
      <div class="w-3 h-3 rounded-full bg-zinc-600"></div>
      <div class="w-3 h-3 rounded-full bg-zinc-600"></div>
    </div>
    <div class="flex-1 bg-zinc-900 rounded-md px-3 py-1.5 flex items-center gap-2 max-w-xs mx-auto">
      <svg class="w-3 h-3 text-zinc-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
      </svg>
      <span class="text-xs text-zinc-500 font-mono truncate">app.bookeroo.com</span>
    </div>
    <div class="w-12"></div>
  </div>

  <!-- Screenshot -->
  <div class="border-x border-b border-zinc-700 rounded-b-xl overflow-hidden shadow-2xl shadow-zinc-950/60">
    <img
      src={src}
      alt={alt}
      class="w-full block"
      loading="lazy"
      decoding="async"
    />
  </div>

  {caption && (
    <p class="text-center text-xs text-zinc-600 mt-3">{caption}</p>
  )}
</div>
