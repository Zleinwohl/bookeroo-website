---
import Layout from '../layouts/Layout.astro';
import FAQ from '../components/FAQ.astro';
import SectionHeader from '../components/SectionHeader.astro';

const demoFaq = [
  { question: "How long is the demo?", answer: "Demos typically run 20–30 minutes. We walk through the platform live and answer all your questions." },
  { question: "Who should attend the demo?", answer: "Whoever makes the decision for your business. Owners, operations managers, or both." },
  { question: "Do I need to prepare anything?", answer: "Nothing at all. Just show up. We handle the walkthrough." },
  { question: "What happens after the demo?", answer: "You get access to try Bookeroo yourself, and we follow up to help you get set up." },
];
---
<Layout title="Book a Demo — Bookeroo" description="See Bookeroo in action. Book a live demo with the team.">

  <section class="py-24 bg-zinc-950">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">

        <!-- Left: copy -->
        <div>
          <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400 mb-4">Book a Demo</p>
          <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-zinc-100 leading-tight mb-6">
            See Bookeroo in action.
          </h1>
          <p class="text-lg text-zinc-400 leading-relaxed mb-8">
            Book a 30-minute live demo with the Bookeroo team. We will walk you through the platform and show you exactly how it fits your operation.
          </p>
          <div class="space-y-4 mb-10">
            {[
              'Live walkthrough of the full platform',
              'Answers to your specific questions',
              'No pressure, no sales pitch',
              'Set up and running in under a day after signing up',
            ].map(item => (
              <div class="flex items-start gap-3">
                <div class="w-5 h-5 rounded-full bg-emerald-500/20 flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                  </svg>
                </div>
                <p class="text-zinc-300">{item}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: booking placeholder -->
        <div class="bg-zinc-900 border border-zinc-800 rounded-2xl p-8">
          <h2 class="font-semibold text-zinc-100 text-xl mb-2">Schedule your demo</h2>
          <p class="text-sm text-zinc-500 mb-8">Pick a time that works for you. We will send a calendar invite right away.</p>
          <div class="bg-zinc-800 border border-zinc-700 rounded-xl p-10 flex flex-col items-center justify-center text-center gap-3 min-h-48">
            <div class="w-12 h-12 rounded-full bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center mb-2">
              <svg class="w-6 h-6 text-emerald-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/>
              </svg>
            </div>
            <p class="text-zinc-400 text-sm">Calendly booking widget</p>
            <p class="text-zinc-600 text-xs">Coming soon — contact us at hello@bookeroo.com to schedule</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="py-24 bg-zinc-950 border-t border-zinc-800/50">
    <div class="max-w-3xl mx-auto px-6">
      <SectionHeader
        eyebrow="Questions"
        heading="About the demo"
        centered={true}
      />
      <FAQ items={demoFaq} />
    </div>
  </section>

</Layout>
