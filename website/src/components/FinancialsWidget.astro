---
// Financial summary widget grounded in real Bookeroo product data
// Real figures: Collected $18,420 (+14.2%), Cash Flow: Gross Revenue $18,420,
// Discount Cost -$86.95, Refunds Issued -$210, Net Revenue $18,123
// Stripe payout integration, Outstanding balances, Revenue by Activity
---

<div class="financials-widget bg-zinc-900 border border-zinc-700 rounded-2xl overflow-hidden shadow-2xl">
  <!-- Header with period filter -->
  <div class="px-5 py-3.5 border-b border-zinc-800 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1.5">
        <div class="w-2.5 h-2.5 rounded-full bg-zinc-700"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-zinc-700"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-zinc-700"></div>
      </div>
      <span class="text-xs text-zinc-500 font-medium">Financials — Overview</span>
    </div>
    <div class="flex items-center gap-1 bg-zinc-800 rounded-lg p-1" id="fin-period-tabs">
      <button class="fin-tab active text-xs font-medium px-2.5 py-1 rounded-md bg-zinc-700 text-zinc-100 transition-all" data-fin="month">This Month</button>
      <button class="fin-tab text-xs font-medium px-2.5 py-1 rounded-md text-zinc-500 hover:text-zinc-300 transition-all" data-fin="last">Last Month</button>
      <button class="fin-tab text-xs font-medium px-2.5 py-1 rounded-md text-zinc-500 hover:text-zinc-300 transition-all" data-fin="year">This Year</button>
    </div>
  </div>

  <div class="p-4">
    <!-- KPI row -->
    <div class="grid grid-cols-2 gap-2 mb-4">
      <div class="bg-zinc-800 rounded-xl p-3">
        <p class="text-xs text-zinc-500 mb-1">Collected</p>
        <p class="text-xl font-semibold font-mono text-zinc-100" id="fin-collected">$18,420</p>
        <p class="text-xs text-emerald-400 mt-0.5">↑ 14.2% vs prior</p>
      </div>
      <div class="bg-zinc-800 rounded-xl p-3 relative">
        <div class="absolute top-2 right-2">
          <span class="text-xs bg-amber-500/15 text-amber-400 border border-amber-500/20 px-1.5 py-0.5 rounded font-medium">Needs attention</span>
        </div>
        <p class="text-xs text-zinc-500 mb-1">Outstanding</p>
        <p class="text-xl font-semibold font-mono text-zinc-100" id="fin-outstanding">$2,340</p>
        <p class="text-xs text-zinc-600 mt-0.5">4 bookings</p>
      </div>
    </div>

    <!-- Stripe payout -->
    <div class="bg-zinc-800/50 border border-zinc-700/50 rounded-xl p-3 mb-4">
      <div class="flex items-center justify-between mb-2">
        <p class="text-xs font-medium text-zinc-400">Next Stripe Payout</p>
        <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
      </div>
      <div class="flex items-end justify-between">
        <div>
          <p class="text-lg font-semibold font-mono text-zinc-100" id="fin-payout">$9,210</p>
          <p class="text-xs text-zinc-500">In Transit</p>
        </div>
        <div class="text-right">
          <p class="text-sm font-mono text-zinc-300" id="fin-pending">$4,890</p>
          <p class="text-xs text-zinc-500">Pending</p>
        </div>
        <div class="text-right">
          <p class="text-xs text-zinc-500">Est. arrival</p>
          <p class="text-xs font-medium text-zinc-300" id="fin-arrival">Mar 19</p>
        </div>
      </div>
    </div>

    <!-- Cash flow -->
    <div>
      <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Cash Flow</p>
      <div class="space-y-1.5">
        {[
          { label: 'Gross Revenue', value: '$18,420', id: 'cf-gross', color: 'text-zinc-200' },
          { label: 'Discount Cost', value: '-$86.95', id: 'cf-discount', color: 'text-amber-400' },
          { label: 'Refunds Issued', value: '-$210.00', id: 'cf-refunds', color: 'text-red-400' },
          { label: 'Net Revenue', value: '$18,123', id: 'cf-net', color: 'text-emerald-400' },
        ].map(row => (
          <div class="flex items-center justify-between py-1 border-b border-zinc-800/50 last:border-0">
            <span class="text-xs text-zinc-500">{row.label}</span>
            <span class:list={["text-xs font-mono font-semibold", row.color]} id={row.id}>{row.value}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<script>
  const finData = {
    month: { collected: '$18,420', outstanding: '$2,340', payout: '$9,210', pending: '$4,890', arrival: 'Mar 19',
             gross: '$18,420', discount: '-$86.95', refunds: '-$210.00', net: '$18,123' },
    last:  { collected: '$14,860', outstanding: '$980', payout: '$7,430', pending: '$2,210', arrival: 'Feb 19',
             gross: '$14,860', discount: '-$62.00', refunds: '-$180.00', net: '$14,618' },
    year:  { collected: '$54,220', outstanding: '$3,840', payout: '$27,110', pending: '$9,450', arrival: 'Mar 19',
             gross: '$54,220', discount: '-$241.00', refunds: '-$680.00', net: '$53,299' },
  };

  const tabs = document.querySelectorAll('.fin-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-zinc-700', 'text-zinc-100');
        t.classList.add('text-zinc-500');
      });
      tab.classList.add('active', 'bg-zinc-700', 'text-zinc-100');
      tab.classList.remove('text-zinc-500');

      const period = tab.getAttribute('data-fin') as keyof typeof finData;
      const d = finData[period];
      document.getElementById('fin-collected')!.textContent = d.collected;
      document.getElementById('fin-outstanding')!.textContent = d.outstanding;
      document.getElementById('fin-payout')!.textContent = d.payout;
      document.getElementById('fin-pending')!.textContent = d.pending;
      document.getElementById('fin-arrival')!.textContent = d.arrival;
      document.getElementById('cf-gross')!.textContent = d.gross;
      document.getElementById('cf-discount')!.textContent = d.discount;
      document.getElementById('cf-refunds')!.textContent = d.refunds;
      document.getElementById('cf-net')!.textContent = d.net;
    });
  });
</script>
