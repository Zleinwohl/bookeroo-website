---
// Interactive mini dashboard widget grounded in real Bookeroo product data
// KPI figures from actual portal: Revenue $18,420 (+14.2%), Bookings 47 (+8.5%),
// Avg. Value $391.9 (+11.3%), Capacity 78% (+4.3%)
---

<div class="dashboard-widget bg-zinc-900 border border-zinc-700 rounded-2xl overflow-hidden shadow-2xl">
  <!-- App chrome -->
  <div class="px-5 py-3.5 border-b border-zinc-800 flex items-center justify-between">
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1.5">
        <div class="w-2.5 h-2.5 rounded-full bg-zinc-700"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-zinc-700"></div>
        <div class="w-2.5 h-2.5 rounded-full bg-zinc-700"></div>
      </div>
      <span class="text-xs text-zinc-500 font-medium">Operations Dashboard</span>
    </div>
    <!-- Period tabs -->
    <div class="flex items-center gap-1 bg-zinc-800 rounded-lg p-1" id="period-tabs">
      <button class="period-tab active text-xs font-medium px-3 py-1 rounded-md transition-all bg-zinc-700 text-zinc-100" data-period="today">Today</button>
      <button class="period-tab text-xs font-medium px-3 py-1 rounded-md transition-all text-zinc-500 hover:text-zinc-300" data-period="week">Week</button>
      <button class="period-tab text-xs font-medium px-3 py-1 rounded-md transition-all text-zinc-500 hover:text-zinc-300" data-period="month">Month</button>
    </div>
  </div>

  <div class="p-4">
    <!-- KPI cards -->
    <div class="grid grid-cols-2 gap-2.5 mb-4">
      <div class="bg-zinc-800 rounded-xl p-3">
        <p class="text-xs text-zinc-500 mb-1">Revenue</p>
        <p class="text-xl font-semibold font-mono text-zinc-100" id="kpi-revenue">$3,240</p>
        <p class="text-xs text-emerald-400 mt-0.5">↑ 14.2% vs prior</p>
      </div>
      <div class="bg-zinc-800 rounded-xl p-3">
        <p class="text-xs text-zinc-500 mb-1">Bookings</p>
        <p class="text-xl font-semibold font-mono text-zinc-100" id="kpi-bookings">9</p>
        <p class="text-xs text-emerald-400 mt-0.5">↑ 8.5% vs prior</p>
      </div>
      <div class="bg-zinc-800 rounded-xl p-3">
        <p class="text-xs text-zinc-500 mb-1">Avg. Booking Value</p>
        <p class="text-xl font-semibold font-mono text-zinc-100" id="kpi-avg">$360</p>
        <p class="text-xs text-emerald-400 mt-0.5">↑ 11.3% vs prior</p>
      </div>
      <div class="bg-zinc-800 rounded-xl p-3">
        <p class="text-xs text-zinc-500 mb-1">Capacity Used</p>
        <p class="text-xl font-semibold font-mono text-zinc-100" id="kpi-capacity">74%</p>
        <p class="text-xs text-emerald-400 mt-0.5">↑ 4.3% vs prior</p>
      </div>
    </div>

    <!-- Stripe Payout mini widget -->
    <div class="bg-zinc-800/60 border border-zinc-700/50 rounded-xl p-3 mb-4 flex items-center justify-between">
      <div>
        <p class="text-xs text-zinc-500 mb-0.5">Next Stripe Payout</p>
        <p class="text-sm font-semibold font-mono text-zinc-100" id="payout-amount">$1,890</p>
      </div>
      <div class="text-right">
        <p class="text-xs text-zinc-500 mb-0.5">Est. arrival</p>
        <p class="text-xs text-zinc-300" id="payout-date">Mar 16</p>
      </div>
      <div class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"></div>
    </div>

    <!-- Today's manifest -->
    <div>
      <p class="text-xs font-semibold text-zinc-500 uppercase tracking-wider mb-2">Today's Manifest</p>
      <div class="space-y-1.5" id="manifest-rows">
        <div class="flex items-center gap-2.5 bg-zinc-800/50 rounded-lg px-3 py-2">
          <div class="w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0"></div>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium text-zinc-200 truncate">Jet Ski + Aqua Kart</p>
            <p class="text-xs text-zinc-600">10:00 AM · 4 guests</p>
          </div>
          <span class="text-xs font-medium text-emerald-400 flex-shrink-0">All clear</span>
        </div>
        <div class="flex items-center gap-2.5 bg-zinc-800/50 rounded-lg px-3 py-2">
          <div class="w-1.5 h-1.5 rounded-full bg-amber-400 flex-shrink-0"></div>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium text-zinc-200 truncate">Buggy & Jet Ski</p>
            <p class="text-xs text-zinc-600">2:00 PM · 3 guests</p>
          </div>
          <span class="text-xs font-medium text-amber-400 flex-shrink-0">Needs attention</span>
        </div>
        <div class="flex items-center gap-2.5 bg-zinc-800/50 rounded-lg px-3 py-2">
          <div class="w-1.5 h-1.5 rounded-full bg-zinc-600 flex-shrink-0"></div>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium text-zinc-200 truncate">Aqua Splash Pack</p>
            <p class="text-xs text-zinc-600">4:30 PM · 6 guests</p>
          </div>
          <span class="text-xs font-medium text-zinc-500 flex-shrink-0">Upcoming</span>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const periodData = {
    today: { revenue: '$3,240', bookings: '9', avg: '$360', capacity: '74%', payout: '$1,890', payoutDate: 'Mar 16' },
    week:  { revenue: '$11,820', bookings: '32', avg: '$369', capacity: '76%', payout: '$5,940', payoutDate: 'Mar 16' },
    month: { revenue: '$18,420', bookings: '47', avg: '$391', capacity: '78%', payout: '$9,210', payoutDate: 'Mar 19' },
  };

  const tabs = document.querySelectorAll('.period-tab');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      tabs.forEach(t => {
        t.classList.remove('active', 'bg-zinc-700', 'text-zinc-100');
        t.classList.add('text-zinc-500');
      });
      tab.classList.add('active', 'bg-zinc-700', 'text-zinc-100');
      tab.classList.remove('text-zinc-500');

      const period = tab.getAttribute('data-period') as keyof typeof periodData;
      const d = periodData[period];
      document.getElementById('kpi-revenue')!.textContent = d.revenue;
      document.getElementById('kpi-bookings')!.textContent = d.bookings;
      document.getElementById('kpi-avg')!.textContent = d.avg;
      document.getElementById('kpi-capacity')!.textContent = d.capacity;
      document.getElementById('payout-amount')!.textContent = d.payout;
      document.getElementById('payout-date')!.textContent = d.payoutDate;
    });
  });
</script>
