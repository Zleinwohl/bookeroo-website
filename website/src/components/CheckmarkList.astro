---
interface Props {
  items: string[];
  class?: string;
}
const { items, class: extraClass } = Astro.props;
---
<ul class:list={["space-y-3", extraClass]}>
  {items.map(item => (
    <li class="flex items-start gap-2.5 text-sm text-zinc-400">
      <svg class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
      </svg>
      {item}
    </li>
  ))}
</ul>
