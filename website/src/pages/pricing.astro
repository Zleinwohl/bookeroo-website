---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import PricingTable from '../components/PricingTable.astro';
import FAQ from '../components/FAQ.astro';
import CTASection from '../components/CTASection.astro';
import SectionHeader from '../components/SectionHeader.astro';

const pricingFaq = [
  { question: "Is there a free trial?", answer: "We offer a guided demo with a live walkthrough of the platform. Get in touch to book yours." },
  { question: "Are there any setup fees?", answer: "No. There are no setup fees. You only pay the monthly plan rate." },
  { question: "Can I change plans later?", answer: "Yes. You can upgrade or downgrade your plan at any time from your account settings." },
  { question: "What payment methods do you accept?", answer: "We accept all major credit and debit cards." },
  { question: "Is there a long-term contract?", answer: "No. All plans are month-to-month. Cancel any time." },
];
---
<Layout title="Pricing — Bookeroo" description="Simple, transparent pricing for tour operators of all sizes.">
  <PageHero
    eyebrow="Pricing"
    heading="Simple, honest pricing."
    subheading="No hidden fees. No confusing tiers. Pick the plan that fits your operation."
  />
  <section class="py-24 bg-zinc-950">
    <div class="max-w-6xl mx-auto px-6">
      <PricingTable />
      <p class="text-center text-sm text-zinc-600 mt-8">All prices in USD. Billed monthly. Cancel any time.</p>
    </div>
  </section>
  <section class="py-24 bg-zinc-950 border-t border-zinc-800/50">
    <div class="max-w-3xl mx-auto px-6">
      <SectionHeader
        eyebrow="Questions"
        heading="Pricing FAQ"
        centered={true}
      />
      <FAQ items={pricingFaq} />
    </div>
  </section>
  <CTASection />
</Layout>
