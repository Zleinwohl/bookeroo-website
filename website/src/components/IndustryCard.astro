---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}
const { title, description, href, icon } = Astro.props;
---
<a href={href} class="group block bg-zinc-900 border border-zinc-800 hover:border-zinc-600 rounded-xl p-6 transition-all hover:-translate-y-1 hover:shadow-xl hover:shadow-zinc-950/50">
  <div class="text-3xl mb-4">{icon}</div>
  <h3 class="font-semibold text-zinc-100 mb-2 group-hover:text-emerald-400 transition-colors">{title}</h3>
  <p class="text-sm text-zinc-500 leading-relaxed">{description}</p>
  <div class="mt-4 flex items-center gap-1.5 text-sm text-emerald-400 opacity-0 group-hover:opacity-100 transition-opacity">
    Learn more
    <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
    </svg>
  </div>
</a>
