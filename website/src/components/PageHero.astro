---
interface Props {
  eyebrow?: string;
  heading: string;
  subheading?: string;
}
const { eyebrow, heading, subheading } = Astro.props;
---
<section class="py-20 md:py-28 bg-zinc-950 border-b border-zinc-800">
  <div class="max-w-6xl mx-auto px-6">
    {eyebrow && (
      <p class="text-sm font-semibold uppercase tracking-wider text-emerald-400 mb-4">{eyebrow}</p>
    )}
    <h1 class="text-4xl md:text-6xl font-semibold tracking-tight text-zinc-100 leading-tight max-w-3xl">
      {heading}
    </h1>
    {subheading && (
      <p class="mt-6 text-xl text-zinc-400 max-w-2xl leading-relaxed">{subheading}</p>
    )}
  </div>
</section>
